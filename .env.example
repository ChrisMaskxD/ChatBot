# WhatsApp AI Bot - Configuração de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais

# ─────────────────────────────────────────────────────────────────────────────
# WhatsApp Integration (escolha uma opção)
# ─────────────────────────────────────────────────────────────────────────────

# Evolution API (Recomendado - Open Source)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-chave-secreta
EVOLUTION_INSTANCE_NAME=bot-local

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI Configuration
# ─────────────────────────────────────────────────────────────────────────────

# API Key do OpenAI (obtenha em https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-sua-chave-aqui

# Modelo padrão para respostas
OPENAI_MODEL=gpt-3.5-turbo

# ─────────────────────────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Chave de criptografia para o banco de dados SQLite (AES-256)
# IMPORTANTE: Altere para uma chave segura em produção!
DB_ENCRYPTION_KEY=Chatbot@2025#Seguro$Database%SQLite&Encrypt#AES256Key!

