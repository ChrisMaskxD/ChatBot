# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
WHATSAPP_TOKEN=seu_token_whatsapp_aqui
PHONE_NUMBER_ID=seu_phone_number_id_aqui
WEBHOOK_VERIFY_TOKEN=seu_verify_token_aqui
WHATSAPP_API_VERSION=v21.0

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sua_openai_api_key_aqui
OPENAI_MODEL=gpt-3.5-turbo

# ─── Catálogo ─────────────────────────────────────────────────────────────────
# URL pública do seu PDF de catálogo (obrigatório para o comando "catalogo")
PDF_CATALOGO_URL=https://seusite.com/catalogo.pdf

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Máximo de mensagens por usuário por janela de tempo
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
